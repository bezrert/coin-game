# Sepolia RPC (Alchemy / Infura / публичный)
SEPOLIA_RPC_URL=

# Приватный ключ кошелька-деплоера (0x...). Держать в секрете, не коммитить.
PRIVATE_KEY=

# ID VRF-подписки, созданной на vrf.chain.link (число uint256)
VRF_SUBSCRIPTION_ID=

# Ключ Etherscan API для верификации исходников
ETHERSCAN_API_KEY=

# --- заполняется ПОСЛЕ деплоя (из вывода Deploy.s.sol) ---
CHIP_ADDRESS=
CASINO_ADDRESS=

# Сумма наполнения банкролла (wei, 18 decimals). 1000 CHIP = один claim крана.
HOUSE_FUNDING=1000000000000000000000
